include(CMakeFindDependencyMacro)

# 版本检查
include(CMakePackageConfigHelpers)

# yaml-cpp 是 hwyz 的链接依赖（静态链接但符号需传递给调用方）
find_dependency(yaml-cpp)

# 定义库相关的变量
set(HWYZ_LIBRARIES HWYZ::hwyz yaml-cpp::yaml-cpp)
set(HWYZ_INCLUDE_DIRS "@CMAKE_INSTALL_PREFIX@/include")

# 包含目标文件
include("${CMAKE_CURRENT_LIST_DIR}/HWYZTargets.cmake")
