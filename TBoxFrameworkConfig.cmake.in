include(CMakeFindDependencyMacro)

# 版本检查
include(CMakePackageConfigHelpers)

# yaml-cpp 是 tbox-framework 的链接依赖（静态链接但符号需传递给调用方）
find_dependency(yaml-cpp)

# 定义库相关的变量
set(TBoxFramework_LIBRARIES TBoxFramework::tbox-framework yaml-cpp::yaml-cpp)
set(TBoxFramework_INCLUDE_DIRS "@CMAKE_INSTALL_PREFIX@/include")

# 包含目标文件
include("${CMAKE_CURRENT_LIST_DIR}/TBoxFrameworkTargets.cmake")